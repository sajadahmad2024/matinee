# ============================================================================
# Flutter Boilerplate 2025 - Environment Configuration Template
# ============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to create environment-specific configurations:
#    - .env.dev (Development)
#    - .env.staging (Staging/Testing)
#    - .env.prod (Production)
# 
# 2. Run the following commands:
#    cp .env.example .env.dev
#    cp .env.example .env.staging
#    cp .env.example .env.prod
# 
# 3. Fill in the actual values for each environment
# 
# 4. NEVER commit .env.* files to git (they're in .gitignore)
# 
# ============================================================================

# ----------------------------------------------------------------------------
# App Configuration
# ----------------------------------------------------------------------------
APP_NAME="Flutter Boilerplate"
APP_ENV="development"  # development, staging, production
APP_VERSION="1.0.0"
APP_BUNDLE_ID="com.example.flutter_boilerplate"
API_SECRET=your-256-bit-secret-here
# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------
API_BASE_URL="https://api.example.com"
API_VERSION="v1"
API_TIMEOUT="30"  # in seconds

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
ENABLE_LOGGING="true"  # Enable console logging
USE_FIREBASE="false"  # Enable Firebase services
ENABLE_CRASH_REPORTING="false"  # Enable crash reporting
ENABLE_ANALYTICS="false"  # Enable analytics tracking
ENABLE_PUSH_NOTIFICATIONS="false"  # Enable FCM push notifications

# ----------------------------------------------------------------------------
# Firebase Configuration (Required only if USE_FIREBASE=true)
# Get these values from Firebase Console > Project Settings
# ----------------------------------------------------------------------------
FIREBASE_API_KEY=""
FIREBASE_PROJECT_ID=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""

# Android specific
FIREBASE_ANDROID_APP_ID=""

# iOS specific
FIREBASE_IOS_APP_ID=""
FIREBASE_IOS_CLIENT_ID=""

# ----------------------------------------------------------------------------
# Google Sign-In Configuration (Optional)
# Get from Google Cloud Console > APIs & Services > Credentials
# ----------------------------------------------------------------------------
GOOGLE_WEB_CLIENT_ID=""
GOOGLE_IOS_CLIENT_ID=""
GOOGLE_ANDROID_CLIENT_ID=""

# ----------------------------------------------------------------------------
# Apple Sign-In Configuration (Optional, iOS only)
# Get from Apple Developer Portal
# ----------------------------------------------------------------------------
APPLE_SERVICE_ID=""
APPLE_REDIRECT_URI=""

# ----------------------------------------------------------------------------
# Social Media OAuth Configuration (Optional)
# ----------------------------------------------------------------------------
# Facebook
FACEBOOK_APP_ID=""
FACEBOOK_CLIENT_TOKEN=""

# Twitter/X
TWITTER_API_KEY=""
TWITTER_API_SECRET=""

# GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ----------------------------------------------------------------------------
# Third-Party Services
# ----------------------------------------------------------------------------
# Sentry (Error Tracking)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"  # development, staging, production

# Google Maps
GOOGLE_MAPS_API_KEY=""

# Stripe (Payment)
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""

# OneSignal (Push Notifications)
ONESIGNAL_APP_ID=""

# Mixpanel (Analytics)
MIXPANEL_TOKEN=""

# Amplitude (Analytics)
AMPLITUDE_API_KEY=""

# ----------------------------------------------------------------------------
# Storage & CDN Configuration (Optional)
# ----------------------------------------------------------------------------
# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_BUCKET_NAME=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ----------------------------------------------------------------------------
# Deep Linking Configuration
# ----------------------------------------------------------------------------
APP_SCHEME="flutterboilerplate"  # Your custom URL scheme
WEB_DOMAIN="example.com"  # Your web domain for universal links

# ----------------------------------------------------------------------------
# Development Tools (Development only)
# ----------------------------------------------------------------------------
ENABLE_DEBUG_MODE="true"
ENABLE_MOCK_DATA="false"
ENABLE_PERFORMANCE_OVERLAY="false"

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# Encryption keys (generate using: openssl rand -base64 32)
ENCRYPTION_KEY=""
JWT_SECRET=""

# ----------------------------------------------------------------------------
# Rate Limiting & Retry Configuration
# ----------------------------------------------------------------------------
MAX_RETRY_ATTEMPTS="3"
RETRY_DELAY_SECONDS="2"
REQUEST_TIMEOUT_SECONDS="30"

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------
CACHE_EXPIRY_HOURS="24"
ENABLE_OFFLINE_MODE="true"

# ----------------------------------------------------------------------------
# Localization Configuration
# ----------------------------------------------------------------------------
DEFAULT_LANGUAGE="en"
SUPPORTED_LANGUAGES="en,es,hi,fr,de"

# ----------------------------------------------------------------------------
# Support & Legal URLs
# ----------------------------------------------------------------------------
SUPPORT_EMAIL="support@example.com"
PRIVACY_POLICY_URL="https://example.com/privacy"
TERMS_OF_SERVICE_URL="https://example.com/terms"
HELP_CENTER_URL="https://example.com/help"

# ----------------------------------------------------------------------------
# Notes:
# - Keep this file updated when adding new environment variables
# - Document any new variables with comments
# - Group related variables together
# - Use SCREAMING_SNAKE_CASE for variable names
# - Quote all values to prevent parsing issues
# ----------------------------------------------------------------------------